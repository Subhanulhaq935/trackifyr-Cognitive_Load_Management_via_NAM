# PostgreSQL connection string (required for auth API routes).
# Local example (matches Docker command in README if you use it):
DATABASE_URL=postgresql://postgres:trackifyr@localhost:5432/trackifyr

# Optional: force TLS for pg (cloud DBs often auto-detected from the URL).
# DATABASE_SSL=true
# Local Postgres without TLS:
# DATABASE_SSL=false

# Optional: override /download link (otherwise uses public/releases/trackifyr-desktop.zip if committed).
# After running the "Desktop release" GitHub Action, point Vercel at the latest ZIP:
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=https://github.com/Subhanulhaq935/trackifyr-Cognitive_Load_Management_via_NAM/releases/latest/download/trackifyr-desktop.zip
